[flake8]
# Align with Black formatter (88 characters)
max-line-length = 88

# Ignore rules that conflict with Black
# E203: Whitespace before ':' (Black formats this)
# W503: Line break before binary operator (Black preference)
extend-ignore = E203, W503

# Exclude common directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    htmlcov,
    instance

# Show source code for each error
show-source = True

# Count the number of occurrences of each error/warning code
count = True

# Print total number of errors
statistics = True
