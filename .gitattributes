# Enforce LF line endings for all text files in the repository
# This ensures consistent behavior across Windows, macOS, and Linux

# Default: normalize all text files to LF
* text=auto eol=lf

# Explicitly mark text files
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.html      text eol=lf
*.css       text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf

# Binary files - do not normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.db        binary
*.sqlite    binary
*.whl       binary
*.egg       binary
*.pyc       binary

