#!/bin/bash
# Tier 2: Pre-commit hook — check and acquire file locks before committing.
#
# Behavior:
#   1. For each staged file, query the lock server.
#   2. If a file is locked by ANOTHER developer: abort the commit with an error.
#   3. If a file is not locked: attempt to acquire a lock automatically.
#   4. If the lock server is unreachable: WARN but allow commit (fail-open by default).
#      Set LOCK_STRICT=1 to fail-closed instead.
#
# Configuration (environment variables):
#   LOCK_SERVER_URL   — default: http://localhost:5001
#   LOCK_DEVELOPER_ID — default: $(git config user.name | tr ' ' '_' | tr '[:upper:]' '[:lower:]')
#   LOCK_BRANCH       — default: $(git branch --show-current)
#   LOCK_STRICT       — default: 0 (fail-open); set to 1 to fail-closed if server unreachable

LOCK_SERVER_URL="${LOCK_SERVER_URL:-http://localhost:5001}"
DEVELOPER_ID="${LOCK_DEVELOPER_ID:-$(git config user.name | tr ' ' '_' | tr '[:upper:]' '[:lower:]')}"
BRANCH_NAME="${LOCK_BRANCH:-$(git branch --show-current 2>/dev/null || echo 'unknown')}"
STRICT="${LOCK_STRICT:-0}"

echo "🔒 Lock check (server: $LOCK_SERVER_URL, developer: $DEVELOPER_ID)"

# Check if lock server is reachable
if ! curl -sf "${LOCK_SERVER_URL}/api/locks/health" > /dev/null 2>&1; then
  if [ "$STRICT" = "1" ]; then
    echo "❌ Lock server unreachable and LOCK_STRICT=1. Aborting commit."
    exit 1
  else
    echo "⚠️  Lock server unreachable. Proceeding without lock check (fail-open mode)."
    exit 0
  fi
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAILED=0

for FILE_PATH in $STAGED_FILES; do
  # Skip non-source files
  if [[ "$FILE_PATH" == *.md ]] || [[ "$FILE_PATH" == *.txt ]] || [[ "$FILE_PATH" == *.yml ]] || [[ "$FILE_PATH" == *.yaml ]]; then
    continue
  fi

  STATUS_RESPONSE=$(curl -sf "${LOCK_SERVER_URL}/api/locks/status?file_path=${FILE_PATH}" 2>/dev/null)

  if [ $? -ne 0 ]; then
    echo "⚠️  Could not check lock for: $FILE_PATH (skipping)"
    continue
  fi

  IS_LOCKED=$(echo "$STATUS_RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(str(d.get('is_locked',False)).lower())" 2>/dev/null)
  LOCKED_BY=$(echo "$STATUS_RESPONSE"  | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('locked_by',''))" 2>/dev/null)

  if [ "$IS_LOCKED" = "true" ] && [ "$LOCKED_BY" != "$DEVELOPER_ID" ]; then
    echo "❌ CONFLICT: $FILE_PATH is locked by '$LOCKED_BY'"
    FAILED=1
    continue
  fi

  if [ "$IS_LOCKED" = "false" ]; then
    ACQUIRE_RESPONSE=$(curl -sf -X POST "${LOCK_SERVER_URL}/api/locks/acquire" \
      -H "Content-Type: application/json" \
      -d "{\"file_path\":\"${FILE_PATH}\",\"developer_id\":\"${DEVELOPER_ID}\",\"branch_name\":\"${BRANCH_NAME}\"}" \
      2>/dev/null)

    if [ $? -eq 0 ]; then
      echo "✅ Lock acquired: $FILE_PATH"
    else
      echo "⚠️  Could not acquire lock for: $FILE_PATH"
    fi
  else
    echo "✅ Already locked by you: $FILE_PATH"
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "❌ Commit blocked: one or more files are locked by another developer."
  echo "   Check the lock dashboard: ${LOCK_SERVER_URL}/admin/lock-dashboard"
  echo "   (Use --no-verify to bypass in emergencies)"
  exit 1
fi

exit 0
