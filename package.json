{
  "name": "mockcmms",
  "version": "1.0.0",
  "description": "A modular Flask-based maintenance management system with a monorepo architecture that supports dynamic loading of specialized applications.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:all": "npm test && npm run test:e2e:chromium",
    "lint": "eslint src/static/js --report-unused-disable-directives",
    "lint:fix": "eslint src/static/js --fix",
    "validate": "python scripts/validate_code.py",
    "validate:quick": "python scripts/validate_code.py --quick",
    "validate:backend": "python scripts/validate_code.py --backend",
    "validate:frontend": "python scripts/validate_code.py --frontend",
    "format": "python scripts/format_code.py",
    "format:check": "python scripts/format_code.py --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KirilMT/mockCMMS.git"
  },
  "keywords": [
    "cmms",
    "maintenance",
    "flask",
    "management"
  ],
  "author": "mockCMMS Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KirilMT/mockCMMS/issues"
  },
  "homepage": "https://github.com/KirilMT/mockCMMS#readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jscpd": "^4.0.5",
    "prettier": "^3.7.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/src/static/js/",
      "<rootDir>/tests/frontend/unit/"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/static/js/**/*.js",
      "!src/static/js/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard",
    "rules": {
      "selector-class-pattern": null,
      "selector-id-pattern": null,
      "no-descending-specificity": null,
      "import-notation": "string",
      "declaration-block-no-duplicate-properties": true,
      "block-no-empty": true
    }
  }
}
