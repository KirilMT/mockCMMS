{
  "name": "mockcmms",
  "version": "1.0.0",
  "description": "A modular Flask-based maintenance management system with a monorepo architecture that supports dynamic loading of specialized applications.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:all": "npm test && npm run test:e2e:chromium"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KirilMT/mockCMMS.git"
  },
  "keywords": [
    "cmms",
    "maintenance",
    "flask",
    "management"
  ],
  "author": "mockCMMS Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KirilMT/mockCMMS/issues"
  },
  "homepage": "https://github.com/KirilMT/mockCMMS#readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@playwright/test": "^1.57.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jscpd": "^4.0.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/src/static/js/",
      "<rootDir>/tests/frontend/unit/"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/static/js/**/*.js",
      "!src/static/js/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 79,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ]
    ]
  }
}
