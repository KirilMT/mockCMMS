# mockCMMS Environment Configuration Example
# Copy this file to .env and update the values for your environment

# =============================================================================
# MAIN APPLICATION (mockCMMS) SETTINGS
# =============================================================================

# Flask secret key - REQUIRED for production
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Debug mode (1/true/yes to enable, 0/false/no to disable)
FLASK_DEBUG=0

# =============================================================================
# MODULAR PACKAGES CONFIGURATION
# =============================================================================

# --- Workforce Manager Package ---
# Enable/disable the Workforce Manager package
WORKFORCE_MANAGER_ENABLED=True

# --- Reports Package ---
# Enable/disable the Reports package
REPORTS_ENABLED=True

# Workforce Manager specific settings
# Force use of test database even when not in debug mode
DEBUG_USE_TEST_DB=0

# Fixed date for testing (ISO format: YYYY-MM-DD or YYYY-MM-DDTHH:MM:SS)
# Only used when FLASK_DEBUG=1
DEBUG_FIXED_DATE=2025-04-19T16:00:00

# Custom database filename (optional)
# If not set, uses testsDB.db in debug mode, weekend_planning.db in production
# DATABASE_FILENAME=custom_database.db

# CSRF token expiration time in seconds (default: 3600 = 1 hour)
CSRF_TIME_LIMIT=3600

# Session lifetime in seconds (default: 1800 = 30 minutes)
SESSION_LIFETIME=1800

# Maximum file upload size in bytes (default: 16777216 = 16MB)
MAX_UPLOAD_SIZE=16777216

# Set the data source for the application.
# - 'api': Use the mockCMMS API
# - 'excel': Use the local Excel file
DATA_SOURCE=api

# =============================================================================
# ADDITIONAL PACKAGE SETTINGS
# =============================================================================

# Reports Package Settings
# No additional settings required - uses main mockCMMS database

# =============================================================================
# FUTURE PACKAGES
# =============================================================================
# Add configuration for additional packages here following the same pattern:
# PACKAGE_NAME_ENABLED=True
# PACKAGE_NAME_SPECIFIC_SETTING=value