# =============================================================================
# CMMS Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# All boolean settings accept: 1/true/yes (enable) or 0/false/no (disable)
# =============================================================================

# =============================================================================
# MAIN APPLICATION (mockCMMS) SETTINGS
# =============================================================================

# Flask secret key - REQUIRED for production.
# Security: Generate a unique key for production deployments.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Debug mode. Enables Flask's auto-reloader and interactive debugger.
# Values: 1/true/yes (enable) | 0/false/no (disable)
# Security: MUST be 0 in production.
FLASK_DEBUG=0

# Port to run the Flask application on.
# Default: 5000
FLASK_RUN_PORT=5000

# Enable E2E Testing mode.
# Values: 1/true/yes (enable) | 0/false/no (disable)
# Purpose: Uses a separate database (mockcmms_e2e.db) for isolation.
E2E_TEST=0

# Auto-seed database on startup. Populates db with dummy data if empty.
# Values: True/False
# Purpose: Useful for first-run setup and development.
AUTO_SEED_DATABASE=True

# Session & Upload Limits
CSRF_TIME_LIMIT=3600            # Token validity in seconds (default: 1 hour)
SESSION_LIFETIME=1800           # Session timeout in seconds (default: 30 min)
MAX_UPLOAD_SIZE=16777216        # Max file upload size in bytes (default: 16MB)

# =============================================================================
# MODULAR PACKAGES CONFIGURATION
# =============================================================================

# Enable/disable the Planning module.
# Values: True/False
# If False, the /planning blueprint will not be registered.
PLANNING_ENABLED=False

# Enable/disable the Reporting module.
# Values: True/False
# If False, the /reporting blueprint will not be registered.
REPORTING_ENABLED=False

# =============================================================================
# PLANNING MODULE SPECIFIC SETTINGS
# =============================================================================

# Data Source Configuration for Planning module.
# Values: 'api' (use mockCMMS REST API - recommended) | 'excel' (legacy/fallback)
DATA_SOURCE=api

# Force Planning module to use its test database (testsDB.db) instead of production (planning.db).
# Values: 1/true/yes (enable) | 0/false/no (disable)
# Purpose: Useful for isolated planning module development without affecting production data.
PLANNING_DEBUG_USE_TEST_DB=0

# Fixed Date for Debugging.
# Format: ISO 8601 (e.g., 2025-04-19T16:00:00)
# Values: 0 (disabled) | ISO date string (enabled)
# Purpose: Forces the Planning module to use a specific date for shift calculations.
#          Useful for testing scenarios that depend on a specific day/time.
DEBUG_FIXED_DATE=0

# =============================================================================
# ADDITIONAL PACKAGE SETTINGS
# =============================================================================

# Reporting Package Settings
# No additional settings required - uses main mockCMMS database.

# =============================================================================
# COLLABORATIVE DEVELOPMENT (SUPABASE) SETTINGS - REQUIRED
# =============================================================================
# Supabase is required for live locking. Create a Supabase project and set these values.
USE_SUPABASE=1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# If set to 1, Git hooks will block the operation if an error occurs
# (e.g. GitHub is down). Default is 1 (fail-secure).
LOCK_STRICT=1
