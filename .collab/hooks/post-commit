#!/bin/sh
# Collaborative file lock — post-commit hook
# Releases locks for committed files after a successful commit.

COLLAB_DIR="$(git rev-parse --show-toplevel)/.collab"
PYTHON="${COLLAB_DIR}/../.venv/Scripts/python.exe"
if [ ! -x "$PYTHON" ]; then
    PYTHON="${COLLAB_DIR}/../.venv/bin/python"
fi
if [ ! -x "$PYTHON" ]; then
    PYTHON="python"
fi

# Get list of files in the last commit
COMMITTED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null)
if [ -z "$COMMITTED" ]; then
    exit 0
fi

echo "[collab] Releasing locks for committed files..."
$PYTHON -c "
import sys, os
sys.path.insert(0, os.path.join('$COLLAB_DIR', '..'))
os.chdir('$(git rev-parse --show-toplevel)')
try:
    from dotenv import load_dotenv
    load_dotenv()
    sys.path.insert(0, '$COLLAB_DIR')
    from core.lock_client import LockClient
    client = LockClient()
    files = '''$COMMITTED'''.strip().split('\n')
    files = [f.strip() for f in files if f.strip()]
    ok, count, msg = client.release_multiple(files)
    print(f'[collab] Released {count} lock(s).')
except Exception as e:
    print(f'[collab] Warning: Lock release failed: {e}', file=sys.stderr)
" 2>&1

# Chain to pre-commit framework if installed
if command -v pre-commit > /dev/null 2>&1; then
    pre-commit run --hook-stage post-commit "$@" 2>/dev/null || true
fi

exit 0
