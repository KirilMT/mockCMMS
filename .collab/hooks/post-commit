#!/bin/sh
# Collaborative file lock — post-commit hook
# Locks are NOT released at commit time; they persist until push.
# This hook only notifies the developer that locks remain active.

COLLAB_DIR="$(git rev-parse --show-toplevel)/.collab"
PYTHON="${COLLAB_DIR}/../.venv/Scripts/python.exe"
if [ ! -x "$PYTHON" ]; then
    PYTHON="${COLLAB_DIR}/../.venv/bin/python"
fi
if [ ! -x "$PYTHON" ]; then
    PYTHON="python"
fi

# Lock lifecycle note:
# Locks are NOT released on commit — they persist until the file is pushed
# and the working tree is clean. The watcher and pre-push hook handle this.
echo "[collab] Commit detected. Locks remain active until files are pushed."

# Chain to pre-commit framework if installed
if command -v pre-commit > /dev/null 2>&1; then
    pre-commit run --hook-stage post-commit "$@" 2>/dev/null || true
fi

exit 0
