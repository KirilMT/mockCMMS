#!/bin/sh
# Collaborative file lock — pre-commit hook
# Acquires locks for all staged files before commit.
# ALWAYS blocks if staged files are locked by another developer.
# Falls back gracefully if the lock client itself is unavailable
# (unless LOCK_STRICT=1, then even client errors block).

COLLAB_DIR="$(git rev-parse --show-toplevel)/.collab"
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
PYTHON="${PROJECT_ROOT}/.venv/Scripts/python.exe"
if [ ! -x "$PYTHON" ]; then
    PYTHON="${PROJECT_ROOT}/.venv/bin/python"
fi
if [ ! -x "$PYTHON" ]; then
    PYTHON="python"
fi

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    exit 0
fi

# If the background watcher daemon is running, it already acquires locks
# for edited files. In that case skip pre-commit lock acquisition to avoid
# redundant operations and false-positive conflicts. This keeps commits
# fast for developers who run the watcher in their editor.
# NOTE: We still chain to the pre-commit framework for linting/testing.
WATCHER_RUNNING=0
PID_FILE="$COLLAB_DIR/.daemon.pid"
if [ -f "$PID_FILE" ]; then
    # .daemon.pid may contain either a plain PID or a JSON payload.
    PID=$($PYTHON -c "
import json
from pathlib import Path

pid_file = Path(r'''$PID_FILE''')
try:
    raw = pid_file.read_text(encoding='utf-8').strip()
except Exception:
    raw = ''

pid = ''
if raw:
    if raw.startswith('{'):
        try:
            payload = json.loads(raw)
            pid = str(payload.get('pid', '')).strip()
        except Exception:
            pid = ''
    else:
        pid = raw.strip()

print(pid)
" 2>/dev/null || true)

    # Guard process checks from non-numeric values.
    case "$PID" in
        ''|*[!0-9]*)
            PID=""
            ;;
    esac

    if [ -n "$PID" ]; then
        # Check process liveness via Python to avoid Git Bash argument
        # conversion issues on Windows (e.g. /FI -> C:/.../FI).
        PID_LIVE=$($PYTHON -c "
import os
import signal
import sys

alive = False
pid = int(sys.argv[1])

try:
    import psutil  # type: ignore

    alive = bool(psutil.pid_exists(pid))
except Exception:
    try:
        os.kill(pid, 0)
        alive = True
    except Exception:
        alive = False

print('1' if alive else '0')
" "$PID" 2>/dev/null || true)

        if [ "$PID_LIVE" = "1" ]; then
            WATCHER_RUNNING=1
        fi
    fi
fi
if [ "$WATCHER_RUNNING" = "1" ]; then
    echo "[collab] Watcher running (PID: $PID) — skipping pre-commit lock acquisition."
fi

if [ "$WATCHER_RUNNING" != "1" ]; then
# Check if LOCK_STRICT is set
LOCK_STRICT="${LOCK_STRICT:-0}"

echo "[collab] Checking locks for staged files..."
export PYTHONUTF8=1
RESULT=$($PYTHON -c "
import sys, os
# Force UTF-8 on Windows (PYTHONUTF8 alone is unreliable in shell capture)
for _s in (sys.stdout, sys.stderr):
    if hasattr(_s, 'reconfigure'):
        try: _s.reconfigure(encoding='utf-8', errors='replace')
        except Exception: pass
sys.path.insert(0, os.path.join('$COLLAB_DIR', '..'))
os.chdir('$PROJECT_ROOT')
try:
    from dotenv import load_dotenv
    load_dotenv()
    sys.path.insert(0, '$COLLAB_DIR')
    from core.lock_client import LockClient
    client = LockClient()
    files = '''$STAGED'''.strip().split('\\n')
    files = [f.strip() for f in files if f.strip()]
    ok, failed, msg = client.acquire_multiple(files, reason='pre-commit')
    if not ok:
        print('[collab] ❌ COMMIT BLOCKED — Lock conflicts detected:', file=sys.stderr)
        print('', file=sys.stderr)
        for f in failed:
            status = client.get_lock_status(f)
            owner = status.get('locked_by', 'unknown')
            print(f'  🔒 {f} — locked by @{owner}', file=sys.stderr)
        print('', file=sys.stderr)
        print('[collab] Resolve conflicts before committing.', file=sys.stderr)
        print('[collab] Run: python collab.py dashboard', file=sys.stderr)
        sys.exit(1)
    print(f'[collab] ✓ Locks acquired for {len(files)} file(s).')
except Exception as e:
    print(f'[collab] Warning: Lock check failed: {e}', file=sys.stderr)
    if os.getenv('LOCK_STRICT', '0') == '1':
        sys.exit(1)
    sys.exit(0)
" 2>&1)

EXIT_CODE=$?
echo "$RESULT"

if [ $EXIT_CODE -ne 0 ]; then
    # Lock conflicts always block — never let conflicting code through
    echo ""
    echo "[collab] ❌ Commit aborted due to file lock conflicts."
    echo "[collab] To view details: python collab.py active"
    echo "[collab] To open dashboard: python collab.py dashboard"
    exit 1
fi
fi

# Find pre-commit in venv (preferred) or fall back to PATH.
# git hook shells on Windows do not include .venv/Scripts in PATH,
# so 'command -v pre-commit' would silently fail without this.
# CRITICAL: Ensure venv/Scripts or venv/bin is in PATH so pre-commit can find
# all development tools (isort, black, ruff, pytest, mypy, flake8, etc.).
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/Scripts/pre-commit.exe"
VENV_SCRIPTS="$PROJECT_ROOT/.venv/Scripts"
VENV_BIN="$PROJECT_ROOT/.venv/bin"

if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/bin/pre-commit"
fi
if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$(command -v pre-commit 2>/dev/null || true)"
fi

if [ -n "$PRE_COMMIT_BIN" ] && [ -x "$PRE_COMMIT_BIN" ]; then
    # Set PATH to include venv/Scripts (Windows) or venv/bin (Unix)
    # This ensures tools like isort, black, ruff, pytest, etc. are available
    if [ -d "$VENV_SCRIPTS" ]; then
        export PATH="$VENV_SCRIPTS:$PATH"
    fi
    if [ -d "$VENV_BIN" ]; then
        export PATH="$VENV_BIN:$PATH"
    fi
    exec "$PRE_COMMIT_BIN" run --hook-stage pre-commit "$@"
fi

exit 0
