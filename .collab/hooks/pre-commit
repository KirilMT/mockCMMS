#!/bin/sh
# Collaborative file lock — pre-commit hook
# Acquires locks for all staged files before commit.
# Falls back gracefully if the lock client is unavailable.

COLLAB_DIR="$(git rev-parse --show-toplevel)/.collab"
PYTHON="${COLLAB_DIR}/../.venv/Scripts/python.exe"
if [ ! -x "$PYTHON" ]; then
    PYTHON="${COLLAB_DIR}/../.venv/bin/python"
fi
if [ ! -x "$PYTHON" ]; then
    PYTHON="python"
fi

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    exit 0
fi

# Check if LOCK_STRICT is set
LOCK_STRICT="${LOCK_STRICT:-0}"

# Attempt to acquire locks
echo "[collab] Checking locks for staged files..."
RESULT=$($PYTHON -c "
import sys, os
sys.path.insert(0, os.path.join('$COLLAB_DIR', '..'))
os.chdir('$(git rev-parse --show-toplevel)')
try:
    from dotenv import load_dotenv
    load_dotenv()
    # Import inline to keep hook self-contained
    sys.path.insert(0, '$COLLAB_DIR')
    from core.lock_client import LockClient
    client = LockClient()
    files = '''$STAGED'''.strip().split('\n')
    files = [f.strip() for f in files if f.strip()]
    ok, failed, msg = client.acquire_multiple(files, reason='pre-commit')
    if not ok:
        for f in failed:
            status = client.get_lock_status(f)
            owner = status.get('locked_by', 'unknown')
            print(f'BLOCKED: {f} is locked by @{owner}', file=sys.stderr)
        sys.exit(1)
    print(f'[collab] Locks acquired for {len(files)} file(s).')
except Exception as e:
    print(f'[collab] Warning: Lock check failed: {e}', file=sys.stderr)
    if os.getenv('LOCK_STRICT', '0') == '1':
        sys.exit(1)
    sys.exit(0)
" 2>&1)

EXIT_CODE=$?
echo "$RESULT"

if [ $EXIT_CODE -ne 0 ]; then
    if [ "$LOCK_STRICT" = "1" ]; then
        echo "[collab] Commit blocked by file lock conflict (LOCK_STRICT=1)."
        exit 1
    else
        echo "[collab] Warning: Lock conflict detected but LOCK_STRICT=0, allowing commit."
        exit 0
    fi
fi

# Chain to pre-commit framework if installed
if command -v pre-commit > /dev/null 2>&1; then
    exec pre-commit run --hook-stage pre-commit "$@"
fi

exit 0
