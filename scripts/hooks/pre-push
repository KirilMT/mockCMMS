#!/bin/sh
# Collaborative file lock pre-push hook.
# Runs pre-push validation and releases locks only when validation succeeds.

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
LOCK_STRICT="${LOCK_STRICT:-0}"

find_collab() {
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.exe" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.exe"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.cmd" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.cmd"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/bin/collab" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/bin/collab"
        return 0
    fi
    command -v collab 2>/dev/null || true
}

PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/Scripts/pre-commit.exe"
VENV_SCRIPTS="$PROJECT_ROOT/.venv/Scripts"
VENV_BIN="$PROJECT_ROOT/.venv/bin"

if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/bin/pre-commit"
fi
if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$(command -v pre-commit 2>/dev/null || true)"
fi

if [ -n "$PRE_COMMIT_BIN" ] && [ -x "$PRE_COMMIT_BIN" ]; then
    if [ -d "$VENV_SCRIPTS" ]; then
        PATH="$VENV_SCRIPTS:$PATH"
        export PATH
    fi
    if [ -d "$VENV_BIN" ]; then
        PATH="$VENV_BIN:$PATH"
        export PATH
    fi
    "$PRE_COMMIT_BIN" run --hook-stage pre-push
    VALIDATION_EXIT=$?
    if [ $VALIDATION_EXIT -ne 0 ]; then
        echo "[collab] Pre-push validation failed - keeping locks active."
        exit $VALIDATION_EXIT
    fi
else
    echo "[collab] Warning: pre-commit not found; skipping pre-push validation."
    echo "[collab] Keeping locks active because validation did not run."
    exit 0
fi

COLLAB_BIN="$(find_collab)"
if [ -z "$COLLAB_BIN" ]; then
    echo "[collab] Warning: collab runtime not found; could not release locks."
    echo "[collab] Install the canonical distribution (never 'pip install collab' — wrong PyPI project):"
    echo "[collab]   Windows: .\\scripts\\setup-dev.ps1"
    echo "[collab]   Or: .venv/Scripts/pip install collab-runtime (pin matches README / COLLAB_RUNTIME_SPEC)"
    if [ "$LOCK_STRICT" = "1" ]; then
        echo "[collab] LOCK_STRICT=1 -> blocking push."
        exit 1
    fi
    exit 0
fi

# Validate collab runtime to detect ambiguous / wrong packages (name collisions).
validate_collab_runtime() {
    PY_EXEC=""
    if [ -x "$PROJECT_ROOT/.venv/Scripts/python.exe" ]; then
        PY_EXEC="$PROJECT_ROOT/.venv/Scripts/python.exe"
    elif [ -x "$PROJECT_ROOT/.venv/bin/python" ]; then
        PY_EXEC="$PROJECT_ROOT/.venv/bin/python"
    else
        PY_EXEC="$(command -v python 2>/dev/null || true)"
    fi

    if [ -z "$PY_EXEC" ]; then
        echo "[collab] Warning: Python not available to validate collab runtime; proceeding without runtime validation." >&2
        return 0
    fi

    # Verify the canonical 'collab-runtime' distribution is installed.
    # An unrelated PyPI package named 'collab' will not provide this metadata,
    # so PackageNotFoundError reliably distinguishes the right runtime from a
    # name-collision install.
    VALID_OUT="$($PY_EXEC - <<PYCODE 2>&1
import sys
try:
    from importlib.metadata import version, PackageNotFoundError
    version('collab-runtime')
except PackageNotFoundError as e:
    sys.stderr.write(f"collab-runtime not installed: {e}")
    sys.exit(2)
except Exception as e:
    sys.stderr.write(str(e))
    sys.exit(2)
sys.exit(0)
PYCODE
)"
    PY_EXIT=$?
    if [ $PY_EXIT -ne 0 ]; then
        echo "[collab] Runtime validation failed: $VALID_OUT" >&2
        echo "[collab] It appears an unrelated package named 'collab' is installed or the runtime is incomplete." >&2
        echo "[collab] Action: set \`COLLAB_RUNTIME_SPEC\` to your approved runtime package and run \`scripts/setup-dev.ps1\` to install it into the project venv." >&2
        echo "[collab] Example (PowerShell):" >&2
        echo "[collab]   \$env:COLLAB_RUNTIME_SPEC='your-org-collab==1.0.0'" >&2
        echo "[collab]   .\\scripts\\setup-dev.ps1" >&2
        if [ "$LOCK_STRICT" = "1" ]; then
            echo "[collab] LOCK_STRICT=1 -> blocking push." >&2
            exit 1
        fi
        return 1
    fi
    return 0
}

validate_collab_runtime || true

echo "[collab] Releasing all locks after successful pre-push validation..."
OUT="$($COLLAB_BIN release-all 2>&1)"
CODE=$?
[ -n "$OUT" ] && printf "%s\n" "$OUT"

if [ $CODE -ne 0 ] && [ "$LOCK_STRICT" = "1" ]; then
    echo "[collab] release-all failed and LOCK_STRICT=1 -> blocking push."
    exit 1
fi

exit 0
