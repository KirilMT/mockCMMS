#!/bin/sh
# Collaborative file lock pre-push hook.
# Runs pre-push validation and releases locks only when validation succeeds.

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
LOCK_STRICT="${LOCK_STRICT:-0}"

find_collab() {
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.exe" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.exe"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.cmd" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.cmd"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/bin/collab" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/bin/collab"
        return 0
    fi
    command -v collab 2>/dev/null || true
}

PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/Scripts/pre-commit.exe"
VENV_SCRIPTS="$PROJECT_ROOT/.venv/Scripts"
VENV_BIN="$PROJECT_ROOT/.venv/bin"

if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/bin/pre-commit"
fi
if [ ! -x "$PRE_COMMIT_BIN" ]; then
    PRE_COMMIT_BIN="$(command -v pre-commit 2>/dev/null || true)"
fi

if [ -n "$PRE_COMMIT_BIN" ] && [ -x "$PRE_COMMIT_BIN" ]; then
    if [ -d "$VENV_SCRIPTS" ]; then
        PATH="$VENV_SCRIPTS:$PATH"
        export PATH
    fi
    if [ -d "$VENV_BIN" ]; then
        PATH="$VENV_BIN:$PATH"
        export PATH
    fi
    "$PRE_COMMIT_BIN" run --hook-stage pre-push
    VALIDATION_EXIT=$?
    if [ $VALIDATION_EXIT -ne 0 ]; then
        echo "[collab] Pre-push validation failed - keeping locks active."
        exit $VALIDATION_EXIT
    fi
else
    echo "[collab] Warning: pre-commit not found; skipping pre-push validation."
    echo "[collab] Keeping locks active because validation did not run."
    exit 0
fi

COLLAB_BIN="$(find_collab)"
if [ -z "$COLLAB_BIN" ]; then
    echo "[collab] Warning: collab runtime not found; could not release locks."
    echo "[collab] Install in project venv: .\\.venv\\Scripts\\pip.exe install collab"
    if [ "$LOCK_STRICT" = "1" ]; then
        echo "[collab] LOCK_STRICT=1 -> blocking push."
        exit 1
    fi
    exit 0
fi

echo "[collab] Releasing all locks after successful pre-push validation..."
OUT="$($COLLAB_BIN release-all 2>&1)"
CODE=$?
[ -n "$OUT" ] && printf "%s\n" "$OUT"

if [ $CODE -ne 0 ] && [ "$LOCK_STRICT" = "1" ]; then
    echo "[collab] release-all failed and LOCK_STRICT=1 -> blocking push."
    exit 1
fi

exit 0
