#!/bin/sh
# Collaborative file lock pre-commit hook.
# Acquires locks for staged files using the installed collab runtime.

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
LOCK_STRICT="${LOCK_STRICT:-0}"

find_collab() {
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.exe" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.exe"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/Scripts/collab.cmd" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/Scripts/collab.cmd"
        return 0
    fi
    if [ -x "$PROJECT_ROOT/.venv/bin/collab" ]; then
        printf "%s" "$PROJECT_ROOT/.venv/bin/collab"
        return 0
    fi
    command -v collab 2>/dev/null || true
}

run_precommit_framework() {
    PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/Scripts/pre-commit.exe"
    VENV_SCRIPTS="$PROJECT_ROOT/.venv/Scripts"
    VENV_BIN="$PROJECT_ROOT/.venv/bin"

    if [ ! -x "$PRE_COMMIT_BIN" ]; then
        PRE_COMMIT_BIN="$PROJECT_ROOT/.venv/bin/pre-commit"
    fi
    if [ ! -x "$PRE_COMMIT_BIN" ]; then
        PRE_COMMIT_BIN="$(command -v pre-commit 2>/dev/null || true)"
    fi

    if [ -n "$PRE_COMMIT_BIN" ] && [ -x "$PRE_COMMIT_BIN" ]; then
        if [ -d "$VENV_SCRIPTS" ]; then
            PATH="$VENV_SCRIPTS:$PATH"
            export PATH
        fi
        if [ -d "$VENV_BIN" ]; then
            PATH="$VENV_BIN:$PATH"
            export PATH
        fi
        exec "$PRE_COMMIT_BIN" run --hook-stage pre-commit "$@"
    fi

    exit 0
}

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    run_precommit_framework "$@"
fi

COLLAB_BIN="$(find_collab)"
if [ -z "$COLLAB_BIN" ]; then
    echo "[collab] Warning: collab runtime not found; lock acquisition skipped."
    echo "[collab] Install in project venv: .\\.venv\\Scripts\\pip.exe install collab"
    if [ "$LOCK_STRICT" = "1" ]; then
        echo "[collab] LOCK_STRICT=1 -> blocking commit."
        exit 1
    fi
    run_precommit_framework "$@"
fi

echo "[collab] Checking locks for staged files..."
FAILED=0
while IFS= read -r file; do
    [ -z "$file" ] && continue
    OUT="$($COLLAB_BIN acquire "$file" --reason "pre-commit" 2>&1)"
    CODE=$?
    [ -n "$OUT" ] && printf "%s\n" "$OUT"
    if [ $CODE -ne 0 ]; then
        FAILED=1
        break
    fi
done <<EOF
$STAGED
EOF

if [ "$FAILED" = "1" ]; then
    echo ""
    echo "[collab] Commit aborted due to file lock conflicts."
    echo "[collab] To inspect locks: collab active"
    echo "[collab] To open dashboard: collab dashboard"
    exit 1
fi

run_precommit_framework "$@"
